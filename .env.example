# =============================================================================
# Customer Portal — Variables d'environnement
# =============================================================================
# Reference pour customer-portal/shared/.env
# Lu par Ansible au deploiement pour templater index.html et manifest.json
# N'est PAS lu directement par le JS (frontend statique)
# =============================================================================


# =============================================================================
# CLINIQUE
# =============================================================================

# Nom complet (titre du navigateur, manifest.json "name", splash screen)
CLINIC_NAME="Clinique Veterinaire des Lilas"

# Nom court (manifest.json "short_name", icone ecran d'accueil)
CLINIC_SHORT_NAME="Vet des Lilas"

# Description PWA (manifest.json "description", meta description)
CLINIC_DESCRIPTION="Suivez la sante de vos animaux, vos rendez-vous et documents veterinaires"


# =============================================================================
# API
# =============================================================================

# URL de base de l'API customer-portal (relative = same-origin)
API_BASE_URL="/api/customer-portal"


# =============================================================================
# PUSH NOTIFICATIONS (VAPID)
# =============================================================================

# Cle publique VAPID — laisser vide pour desactiver les push
VAPID_PUBLIC_KEY=""


# =============================================================================
# THEMING
# =============================================================================

# Couleur principale (barre de statut mobile, manifest.json "theme_color")
THEME_COLOR="#1B3A4B"

# Couleur de fond au lancement (manifest.json "background_color")
BACKGROUND_COLOR="#F5F7FA"


# =============================================================================
# ICONES PWA
# =============================================================================
# Chemins relatifs vers les icones. Laisser vide = fallback Infravet par defaut.
# Les fichiers doivent etre deposes dans assets/logo/ ou un chemin accessible.

ICON_96=""
ICON_192=""
ICON_512=""
APPLE_TOUCH_ICON=""


# =============================================================================
# VERSIONING
# =============================================================================

APP_VERSION="0.0.1"
APP_COMMIT=""


# =============================================================================
# DEPLOIEMENT ANSIBLE — INSTRUCTIONS
# =============================================================================
#
# Fichiers a templater :
#
#   1. index.html
#      - Injecter le bloc suivant AVANT <script src="js/config.js"> :
#
#        <script>
#        window.INFRAVET_CONFIG = {
#            API_BASE_URL: "{{ API_BASE_URL }}",
#            VAPID_PUBLIC_KEY: "{{ VAPID_PUBLIC_KEY }}",
#            APP_VERSION: "{{ APP_VERSION }}"
#        };
#        </script>
#
#      - Remplacer <title> par {{ CLINIC_NAME }}
#      - Remplacer <meta name="theme-color" content="..."> par {{ THEME_COLOR }}
#      - Remplacer <meta name="description" content="..."> par {{ CLINIC_DESCRIPTION }}
#      - Si ICON_96 fourni : remplacer href dans <link rel="icon" ...>
#      - Si APPLE_TOUCH_ICON fourni : remplacer href dans <link rel="apple-touch-icon" ...>
#
#   2. manifest.json
#      - "name": "{{ CLINIC_NAME }}"
#      - "short_name": "{{ CLINIC_SHORT_NAME }}"
#      - "description": "{{ CLINIC_DESCRIPTION }}"
#      - "theme_color": "{{ THEME_COLOR }}"
#      - "background_color": "{{ BACKGROUND_COLOR }}"
#      - Si ICON_96/192/512 fournis : remplacer les "src" dans "icons"
#
# Production — securite :
#
#   - NE PAS deployer le dossier mocks/
#   - RETIRER la ligne <script src="mocks/mock-server.js"> de index.html
#   - CSP (Content-Security-Policy) dans index.html :
#       - Retirer ws://localhost:* et ws://127.0.0.1:* de connect-src
#       - Retirer https://picsum.photos et https://fastly.picsum.photos de img-src
#       - Si API same-origin : connect-src 'self' suffit
#       - Si API cross-origin : ajouter le domaine API a connect-src
#       - Garder 'unsafe-inline' dans script-src (necessaire pour le bloc INFRAVET_CONFIG)
#
# =============================================================================
